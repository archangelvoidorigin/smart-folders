{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ArchangelVoidOrigin/smart-folders/settings-schema.json",
  "title": "Smart Folder Settings",
  "description": "Configuration schema for smart-folder settings.json files",
  "type": "object",
  "required": ["folder", "boundaries"],
  "additionalProperties": false,
  "properties": {
    "folder": {
      "type": "object",
      "required": ["name", "role"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "role": {
          "type": "string",
          "enum": [
            "Knowledge Keeper",
            "Creator",
            "Architect",
            "Connector",
            "Chronicler",
            "Enabler",
            "Archive",
            "Staging",
            "Custom"
          ]
        },
        "sub_role": { "type": ["string", "null"] },
        "level": { "type": "integer", "minimum": 0, "maximum": 10 },
        "depth": { "type": "string", "enum": ["shallow", "medium", "deep"] },
        "purpose": { "type": "string", "maxLength": 300 }
      }
    },
    "boundaries": {
      "type": "object",
      "required": ["can_see", "cannot_see"],
      "additionalProperties": false,
      "properties": {
        "can_see": { "type": "array", "items": { "type": "string" } },
        "cannot_see": { "type": "array", "items": { "type": "string" } },
        "token_budget": { "type": "integer", "minimum": 1000, "maximum": 50000, "default": 8000 },
        "file_limit": { "type": "integer", "minimum": 10, "maximum": 10000, "default": 500 },
        "depth_limit": { "type": "integer", "minimum": 1, "maximum": 10, "default": 5 }
      }
    },
    "connections": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "parent": { "type": ["string", "null"] },
        "children": { "type": "array", "items": { "type": "string" } },
        "siblings": { "type": "array", "items": { "type": "string" } },
        "tools": { "type": "array", "items": { "type": "string" } },
        "feeds_into": { "type": "array", "items": { "type": "string" } },
        "receives_from": { "type": "array", "items": { "type": "string" } }
      }
    },
    "agents": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed": {
          "type": "array",
          "items": { "type": "string", "enum": ["claude", "gemini", "codex", "cursor", "kilo", "aider"] }
        },
        "preferred": { "type": "string" },
        "restricted": { "type": "array", "items": { "type": "string" } }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "author": { "type": "string" },
        "last_modified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "quality_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "version": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
